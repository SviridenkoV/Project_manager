<div class="min-h-screen flex items-center justify-center px-4 py-12" style="min-height: 100vh; display: flex; align-items: center; justify-content: center;">
  <div class="w-full max-w-md" style="width: 100%; max-width: 28rem;">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-white" style="font-size: 1.875rem; font-weight: 700; color: white;">
        Project<span class="text-purple-400" style="color: #a78bfa;">Manager</span>
      </h1>
      <p class="text-white/60 mt-2" style="color: rgba(255,255,255,0.6); margin-top: 0.5rem;">Создайте новый аккаунт</p>
    </div>

    <div class="bg-white/10 backdrop-blur-lg rounded-2xl p-8 border border-white/10 shadow-2xl" style="background: rgba(255,255,255,0.06); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border-radius: 1rem; padding: 2rem; border: 1px solid rgba(255,255,255,0.06); box-shadow: 0 8px 32px rgba(0,0,0,0.4);">
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { style: "width: 100%;" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>
        
        <div class="mb-4">
          <%= f.label :email, class: "block text-sm font-medium text-white/80 mb-1", style: "display: block; font-size: 0.875rem; font-weight: 500; color: rgba(255,255,255,0.8); margin-bottom: 0.25rem;" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
                placeholder: "you@example.com",
                class: "w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-purple-400 focus:border-transparent transition",
                style: "width: 100%; padding: 0.75rem 1rem; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); border-radius: 0.75rem; color: #f1f5f9; transition: all 0.3s ease; box-sizing: border-box;" %>
        </div>

        <div class="mb-4">
          <%= f.label :password, class: "block text-sm font-medium text-white/80 mb-1", style: "display: block; font-size: 0.875rem; font-weight: 500; color: rgba(255,255,255,0.8); margin-bottom: 0.25rem;" %>
          <%= f.password_field :password, autocomplete: "new-password",
                placeholder: "••••••••",
                class: "w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-purple-400 focus:border-transparent transition",
                style: "width: 100%; padding: 0.75rem 1rem; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); border-radius: 0.75rem; color: #f1f5f9; transition: all 0.3s ease; box-sizing: border-box;" %>
          <p class="text-xs text-white/40 mt-1" style="font-size: 0.75rem; color: rgba(255,255,255,0.4); margin-top: 0.25rem;">Минимум 6 символов</p>
        </div>

        <div class="mb-6">
          <%= f.label :password_confirmation, class: "block text-sm font-medium text-white/80 mb-1", style: "display: block; font-size: 0.875rem; font-weight: 500; color: rgba(255,255,255,0.8); margin-bottom: 0.25rem;" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password",
                placeholder: "••••••••",
                class: "w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-purple-400 focus:border-transparent transition",
                style: "width: 100%; padding: 0.75rem 1rem; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); border-radius: 0.75rem; color: #f1f5f9; transition: all 0.3s ease; box-sizing: border-box;" %>
        </div>

        <%= f.submit "Зарегистрироваться", class: "w-full py-3 px-4 bg-gradient-to-r from-purple-500 to-pink-500 hover:from-purple-600 hover:to-pink-600 text-white font-semibold rounded-xl shadow-lg shadow-purple-500/25 hover:shadow-purple-500/40 transition duration-200 cursor-pointer",
              style: "width: 100%; padding: 0.75rem 1rem; background: linear-gradient(135deg, #7c3aed, #6d28d9); color: white; font-weight: 600; border: none; border-radius: 0.75rem; cursor: pointer; transition: all 0.3s ease; box-shadow: 0 4px 15px rgba(124,58,237,0.3);" %>
      <% end %>

      <div class="mt-6 text-center border-t border-white/10 pt-6" style="margin-top: 1.5rem; text-align: center; border-top: 1px solid rgba(255,255,255,0.06); padding-top: 1.5rem;">
        <p class="text-white/60" style="color: rgba(255,255,255,0.6);">
          Уже есть аккаунт?
          <%= link_to "Войти", new_session_path(resource_name), class: "text-purple-300 hover:text-purple-200 font-medium transition", style: "color: #a78bfa; text-decoration: none; font-weight: 500; transition: all 0.3s ease;" %>
        </p>
      </div>
    </div>
  </div>
</div>