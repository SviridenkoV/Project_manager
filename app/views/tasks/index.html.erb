<h1>Задачи проекта: <%= @project.title %></h1>

<%= link_to "Новая задача", new_project_task_path(@project), class: "btn btn-primary" %>

<div style="display: flex; gap: 20px; margin-top: 20px; flex-wrap: wrap;">
  <% custom_order = [:to_do, :rejected, :in_progress, :in_testing, :done] %>

  <% custom_order.each do |status| %>
    <div style="flex: 1; border: 1px solid #ccc; padding: 10px; border-radius: 8px; min-height: 200px;">
      <h3><%= status.to_s.humanize %></h3>

      <ul style="list-style: none; padding: 0;">
        <% @tasks_by_status[status.to_s]&.each do |task| %>
          <li style="margin-bottom: 10px; padding: 10px; background: #f9f9f9; border-radius: 4px;">
            <strong><%= task.title %></strong>

            <br>

            <span class="priority-badge priority-<%= task.priority %>">
              <%= task.priority&.humanize || "Средний" %>
            </span>

            <p><%= task.description %></p>

            <div style="margin-top: 6px;">
              <%= link_to "Просмотр", project_task_path(@project, task), class: "btn btn-sm btn-secondary" %>
              <%= link_to "Редактировать", edit_project_task_path(@project, task), class: "btn btn-sm btn-outline" %>
              <%= button_to "Удалить", project_task_path(@project, task), method: :delete, data: { confirm: "Точно?" }, class: "btn btn-sm btn-danger" %>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>
</div>

<%= link_to "Назад к проекту", @project, class: "btn btn-outline mt-4" %>