<h1 class="text-2xl font-bold mb-4">Задачи проекта: <%= @project.title %></h1>

<%= link_to "Новая задача", new_project_task_path(@project), class: "btn btn-primary mb-4" %>

<div class="flex gap-4 mt-4 overflow-x-auto" style="display: flex; gap: 20px; margin-top: 20px; flex-wrap: wrap;">
  <% custom_order = [:to_do, :rejected, :in_progress, :in_testing, :done] %>

  <% custom_order.each do |status| %>
    <div class="bg-white/10 backdrop-blur-sm p-4 rounded-xl border border-white/10 flex-1 min-w-[200px]" style="flex: 1; border: 1px solid rgba(255,255,255,0.1); padding: 10px; border-radius: 8px; min-height: 200px;">
      <h3 class="text-lg font-semibold text-white mb-3"><%= t("statuses.#{status}") %></h3>

      <ul style="list-style: none; padding: 0;">
        <% @tasks_by_status[status.to_s]&.each do |task| %>
          <li class="bg-white/5 backdrop-blur-sm p-4 rounded-lg border border-white/10 hover:bg-white/10 transition mb-3" style="margin-bottom: 10px; padding: 10px; background: rgba(255,255,255,0.05); border-radius: 4px;">
            <strong class="text-white"><%= task.title %></strong>

            <br>

            <span class="priority-badge priority-<%= task.priority %>">
              <%= t("priorities.#{task.priority}") %>
            </span>

            <p class="text-white/70 mt-1"><%= task.description %></p>

            <div class="flex gap-2 mt-3 flex-wrap">
              <%= link_to t('views.tasks.show.view'), project_task_path(@project, task), class: "btn btn-sm btn-secondary" %>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>
</div>

<%= link_to t('views.tasks.index.back_to_project'), @project, class: "btn btn-outline mt-4" %>