<h1><%= @task.title %></h1>

<p><strong>Описание:</strong> <%= @task.description %></p>

<p>
  <strong>Статус:</strong>
  <span class="badge badge-<%= @task.status %>">
    <%= @task.status.humanize %>
  </span>
</p>

<p>
  <strong>Приоритет:</strong>
  <span class="priority-badge priority-<%= @task.priority %>">
    <%= @task.priority&.humanize || "Средний" %>
  </span>
</p>

<p><strong>Подсказка по статусам:</strong> <%= @task.transitions_hint %></p>

<div style="margin-top: 20px;">
  <%= link_to "Редактировать", edit_project_task_path(@project, @task), class: "btn btn-secondary" %>
  <%= button_to "Удалить", project_task_path(@project, @task), method: :delete, data: { confirm: "Точно?" }, class: "btn btn-danger" %>
  <%= link_to "Назад к задачам", project_tasks_path(@project), class: "btn btn-outline" %>
</div>