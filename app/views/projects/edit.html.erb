<h1><%= t('views.projects.edit.title') %></h1>

<%= form_with model: @project do |form| %>
  <div>
    <%= form.label :title %>
    <%= form.text_field :title %>
  </div>

  <div>
    <%= form.label :description %>
    <%= form.text_area :description %>
  </div>

  <%= form.submit t('helpers.submit.project.update') %>
<% end %>

<%= link_to t('views.projects.edit.back'), @project %>